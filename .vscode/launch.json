{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Current File",
      "type": "python",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Python: generate_data.py",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/generate_data.py",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Python: analysis_bot.py",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/analysis_bot.py",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Streamlit: dashboard.py",
      "type": "python",
      "request": "launch",
      "module": "streamlit",
      "args": ["run", "${workspaceFolder}/dashboard.py"],
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
